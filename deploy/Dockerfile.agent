# AutoSRE agent — served via `python -m autosre.server` on Cloud Run.
# Implements the CONTRACT.md HTTP+SSE endpoints (incident start/stream/approval,
# demo inject/reset/health). sse-starlette + all requirements.txt are installed.
FROM python:3.13-slim

# Node is needed only for DYNATRACE_MCP_MODE=stdio (npx official server).
RUN apt-get update && apt-get install -y --no-install-recommends nodejs npm \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY autosre ./autosre

# Default to the model actually available on this project's Vertex. pro-preview is
# not allowlisted here; override AUTOSRE_MODEL where pro is enabled.
ENV PYTHONUNBUFFERED=1 \
    DYNATRACE_MCP_MODE=mock \
    AUTOSRE_MODEL=gemini-3-flash-preview

# Cloud Run provides $PORT.
# python -m autosre.server starts uvicorn on that port (see autosre/server/__main__.py).
CMD exec python -m autosre.server
