# ─── Gemini / Google Cloud ────────────────────────────────────────────────
# Option A (simplest): Gemini API key from Google AI Studio
GOOGLE_API_KEY=your-gemini-api-key
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Option B (production): Vertex AI on Google Cloud. Set USE_VERTEXAI=TRUE and
# authenticate with `gcloud auth application-default login`.
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Model used by the AutoSRE agent (hackathon requires Gemini 3).
# gemini-3-flash-preview works on the free AI Studio tier. gemini-3-pro-preview
# gives stronger reasoning but needs a billing-enabled project (free tier = 0 quota).
AUTOSRE_MODEL=gemini-3-flash-preview

# ─── Dynatrace MCP source ─────────────────────────────────────────────────
# mock  -> run fully offline against the bundled mock Dynatrace MCP server
# stdio -> run the official npx @dynatrace-oss/dynatrace-mcp-server locally
# remote-> connect to your Dynatrace tenant's remote MCP gateway
DYNATRACE_MCP_MODE=mock

# Required for stdio/remote modes. e.g. https://abc12345.apps.dynatrace.com
DT_ENVIRONMENT=
# Platform token (remote/stdio non-interactive). Scopes:
#   mcp-gateway:servers:invoke, mcp-gateway:servers:read, storage:logs:read,
#   storage:metrics:read, storage:events:read
DT_PLATFORM_TOKEN=

# ─── Demo target service ──────────────────────────────────────────────────
# The "checkout-api" the agent observes and remediates.
TARGET_SERVICE_URL=http://localhost:8081
